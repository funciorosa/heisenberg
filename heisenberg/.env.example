# HEISENBERG — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Polymarket Relayer API (Settings → Claves API del Relayer → Crear nuevo)
POLY_RELAYER_API_KEY=your_relayer_key_here
POLY_RELAYER_ADDRESS=your_signer_address_here

# Optional: override defaults
# POLL_INTERVAL_SECONDS=5
# BANKROLL=1000
# KELLY_FRACTION=0.25
