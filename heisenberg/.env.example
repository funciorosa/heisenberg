# HEISENBERG — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Capital (USDC)
STARTING_CAPITAL=100
PAPER_TRADING=true

# Server
PORT=8000

# Polymarket Relayer API (Settings → Claves API del Relayer → Crear nuevo)
POLY_RELAYER_API_KEY=your_relayer_key_here
POLY_RELAYER_ADDRESS=0x...
